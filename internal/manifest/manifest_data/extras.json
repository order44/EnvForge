{
  "id": "extras",
  "name": "Extras",
  "description": "Browsers, system optimization and desktop apps",
  "subcategories": [
    {
      "id": "browsers",
      "name": "Browsers",
      "packages": [
        {
          "id": "firefox",
          "name": "firefox",
          "description": "Mozilla Firefox browser",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v firefox || command -v firefox-esr",
              "commands": [
                "set -e && apt-get install -y firefox 2>/dev/null || apt-get install -y firefox-esr"
              ],
              "size_kb": 260000
            },
            "windows": {
              "method": "winget",
              "id": "Mozilla.Firefox"
            }
          }
        },
        {
          "id": "chromium",
          "name": "chromium",
          "description": "Open-source Chrome browser",
          "default": false,
          "platforms": {
            "linux": {
              "method": "apt",
              "packages": [
                "chromium"
              ],
              "check": "command -v chromium"
            },
            "windows": {
              "method": "winget",
              "id": "Hibbiki.Chromium"
            }
          }
        }
      ]
    },
    {
      "id": "db",
      "name": "Database Tools",
      "packages": [
        {
          "id": "sqlite3",
          "name": "sqlite3",
          "description": "SQLite CLI",
          "default": true,
          "platforms": {
            "linux": {
              "method": "apt",
              "packages": [
                "sqlite3"
              ],
              "check": "command -v sqlite3"
            }
          }
        },
        {
          "id": "dbeaver",
          "name": "dbeaver",
          "description": "Universal database GUI",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v dbeaver || dpkg -s dbeaver-ce >/dev/null 2>&1",
              "commands": [
                "set -e && ARCH=$(dpkg --print-architecture) && if [ \"$ARCH\" != \"amd64\" ]; then echo \"DBeaver CE upstream publishes only amd64 .deb in this installer\" >&2; exit 1; fi && curl -fsSLo /tmp/dbeaver.deb https://dbeaver.io/files/dbeaver-ce_latest_amd64.deb && apt-get install -y /tmp/dbeaver.deb && rm -f /tmp/dbeaver.deb"
              ],
              "size_kb": 230000
            },
            "windows": {
              "method": "winget",
              "id": "dbeaver.dbeaver"
            }
          }
        }
      ]
    },
    {
      "id": "apps",
      "name": "Desktop Apps",
      "packages": [
        {
          "id": "keepassxc",
          "name": "keepassxc",
          "description": "Password manager",
          "default": false,
          "platforms": {
            "linux": {
              "method": "apt",
              "packages": [
                "keepassxc"
              ],
              "check": "command -v keepassxc"
            },
            "windows": {
              "method": "winget",
              "id": "KeePassXCTeam.KeePassXC"
            }
          }
        },
        {
          "id": "vlc",
          "name": "vlc",
          "description": "Media player",
          "default": false,
          "platforms": {
            "linux": {
              "method": "apt",
              "packages": [
                "vlc"
              ],
              "check": "command -v vlc"
            },
            "windows": {
              "method": "winget",
              "id": "VideoLAN.VLC"
            }
          }
        },
        {
          "id": "flameshot",
          "name": "flameshot",
          "description": "Screenshot tool",
          "default": false,
          "platforms": {
            "linux": {
              "method": "apt",
              "packages": [
                "flameshot"
              ],
              "check": "command -v flameshot"
            },
            "windows": {
              "method": "winget",
              "id": "Flameshot.Flameshot"
            }
          }
        }
      ]
    },
    {
      "id": "win_optimize",
      "name": "Windows Optimization",
      "packages": [
        {
          "id": "powertoys",
          "name": "PowerToys",
          "description": "Microsoft power-user utilities",
          "default": true,
          "platforms": {
            "windows": {
              "method": "winget",
              "id": "Microsoft.PowerToys"
            }
          }
        },
        {
          "id": "win-terminal",
          "name": "Windows Terminal",
          "description": "Modern terminal for Windows",
          "default": true,
          "platforms": {
            "windows": {
              "method": "winget",
              "id": "Microsoft.WindowsTerminal"
            }
          }
        }
      ]
    }
  ]
}
