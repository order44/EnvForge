{
  "id": "languages",
  "name": "Programming Languages",
  "description": "Compilers, runtimes, LSPs, package managers",
  "subcategories": [
    {
      "id": "python",
      "name": "Python",
      "packages": [
        {
          "id": "python3",
          "name": "python3",
          "description": "Python 3 interpreter + pip + venv",
          "default": true,
          "platforms": {
            "linux":   { "method": "apt", "packages": ["python3", "python3-pip", "python3-venv", "python3-dev"], "check": "command -v python3 && command -v pip3" },
            "windows": { "method": "winget", "id": "Python.Python.3.12" }
          }
        },
        {
          "id": "uv",
          "name": "uv",
          "description": "Fast Python package manager (Rust)",
          "default": true,
          "platforms": {
            "linux":   { "method": "custom", "check": "command -v uv", "commands": ["curl -LsSf https://astral.sh/uv/install.sh | sh"] },
            "windows": { "method": "winget", "id": "astral-sh.uv" }
          }
        },
        {
          "id": "pyenv",
          "name": "pyenv",
          "description": "Python version manager",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "test -d \"${PYENV_ROOT:-$HOME/.pyenv}\" || test -d /root/.pyenv || test -d /home/${SUDO_USER:-$USER}/.pyenv",
              "commands": [
                "set -e && apt-get install -y make libssl-dev zlib1g-dev libbz2-dev libreadline-dev libsqlite3-dev llvm libncursesw5-dev xz-utils tk-dev libxml2-dev libxmlsec1-dev libffi-dev liblzma-dev && REAL_HOME=$(eval echo ~${SUDO_USER:-$USER}) && HOME=$REAL_HOME curl -fsSL https://pyenv.run | HOME=$REAL_HOME bash && chown -R ${SUDO_USER:-$USER}: $REAL_HOME/.pyenv 2>/dev/null || true"
              ]
            }
          }
        },
        {
          "id": "ruff",
          "name": "ruff",
          "description": "Python linter + formatter (Rust)",
          "default": true,
          "platforms": {
            "linux":   { "method": "pip", "packages": ["ruff"], "check": "command -v ruff" },
            "windows": { "method": "winget", "id": "astral-sh.Ruff" }
          }
        },
        {
          "id": "mypy",
          "name": "mypy",
          "description": "Static type checker for Python",
          "default": false,
          "platforms": {
            "linux":   { "method": "pip", "packages": ["mypy"], "check": "command -v mypy" },
            "windows": { "method": "pip", "packages": ["mypy"] }
          }
        },
        {
          "id": "black",
          "name": "black",
          "description": "Python code formatter",
          "default": false,
          "platforms": {
            "linux":   { "method": "pip", "packages": ["black"], "check": "command -v black" },
            "windows": { "method": "pip", "packages": ["black"] }
          }
        },
        {
          "id": "poetry",
          "name": "poetry",
          "description": "Python dependency manager",
          "default": false,
          "platforms": {
            "linux":   { "method": "pip", "packages": ["poetry"], "check": "command -v poetry" },
            "windows": { "method": "pip", "packages": ["poetry"] }
          }
        }
      ]
    },
    {
      "id": "golang",
      "name": "Go",
      "packages": [
        {
          "id": "go",
          "name": "go",
          "description": "Go compiler and tools",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v go || test -x /usr/local/go/bin/go",
              "commands": [
                "set -e && GO_VERSION=$(curl -fsSL https://go.dev/VERSION?m=text | head -1) && curl -fsSL https://go.dev/dl/${GO_VERSION}.linux-amd64.tar.gz | tar -C /usr/local -xzf - && ln -sf /usr/local/go/bin/go /usr/local/bin/go && ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt"
              ]
            },
            "windows": { "method": "winget", "id": "GoLang.Go" }
          }
        },
        {
          "id": "gopls",
          "name": "gopls",
          "description": "Go LSP server",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v gopls",
              "commands": ["GOBIN=/usr/local/bin /usr/local/go/bin/go install golang.org/x/tools/gopls@latest"]
            }
          }
        },
        {
          "id": "golangci-lint",
          "name": "golangci-lint",
          "description": "Go linter aggregator",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v golangci-lint",
              "commands": ["GOBIN=/usr/local/bin /usr/local/go/bin/go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest"]
            }
          }
        },
        {
          "id": "delve",
          "name": "delve",
          "description": "Go debugger",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v dlv",
              "commands": ["GOBIN=/usr/local/bin /usr/local/go/bin/go install github.com/go-delve/delve/cmd/dlv@latest"]
            }
          }
        },
        {
          "id": "air",
          "name": "air",
          "description": "Live reload for Go apps",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v air",
              "commands": ["GOBIN=/usr/local/bin /usr/local/go/bin/go install github.com/air-verse/air@latest"]
            }
          }
        }
      ]
    },
    {
      "id": "rust",
      "name": "Rust",
      "packages": [
        {
          "id": "rustup",
          "name": "rustup",
          "description": "Rust toolchain installer",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v rustup || test -x $HOME/.cargo/bin/rustup",
              "commands": ["curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable"]
            },
            "windows": { "method": "winget", "id": "Rustlang.Rustup" }
          }
        },
        {
          "id": "rust-analyzer",
          "name": "rust-analyzer",
          "description": "Rust LSP server",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v rust-analyzer",
              "commands": [". $HOME/.cargo/env 2>/dev/null; rustup component add rust-analyzer"]
            }
          }
        },
        {
          "id": "clippy",
          "name": "clippy",
          "description": "Rust linter",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": ". $HOME/.cargo/env 2>/dev/null; cargo clippy --version >/dev/null 2>&1",
              "commands": [". $HOME/.cargo/env 2>/dev/null; rustup component add clippy"]
            }
          }
        },
        {
          "id": "rustfmt",
          "name": "rustfmt",
          "description": "Rust code formatter",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": ". $HOME/.cargo/env 2>/dev/null; cargo fmt --version >/dev/null 2>&1",
              "commands": [". $HOME/.cargo/env 2>/dev/null; rustup component add rustfmt"]
            }
          }
        }
      ]
    },
    {
      "id": "js_ts",
      "name": "JavaScript / TypeScript",
      "packages": [
        {
          "id": "nvm",
          "name": "nvm",
          "description": "Node version manager",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "test -d /usr/local/nvm || test -d $HOME/.nvm",
              "commands": [
                "set -e && export NVM_DIR=/usr/local/nvm && mkdir -p $NVM_DIR && curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/master/install.sh | PROFILE=/dev/null bash && . $NVM_DIR/nvm.sh && nvm install --lts && ln -sf $(which node) /usr/local/bin/node && ln -sf $(which npm) /usr/local/bin/npm"
              ]
            },
            "windows": { "method": "winget", "id": "CoreyButler.NVMforWindows" }
          }
        },
        {
          "id": "pnpm",
          "name": "pnpm",
          "description": "Fast npm alternative",
          "default": false,
          "platforms": {
            "linux":   { "method": "npm", "packages": ["pnpm"], "check": "command -v pnpm" },
            "windows": { "method": "winget", "id": "pnpm.pnpm" }
          }
        },
        {
          "id": "typescript",
          "name": "typescript",
          "description": "TypeScript compiler",
          "default": true,
          "platforms": {
            "linux":   { "method": "npm", "packages": ["typescript"], "check": "command -v tsc" },
            "windows": { "method": "npm", "packages": ["typescript"] }
          }
        },
        {
          "id": "tsx",
          "name": "tsx",
          "description": "Run TypeScript directly",
          "default": false,
          "platforms": {
            "linux":   { "method": "npm", "packages": ["tsx"], "check": "command -v tsx" },
            "windows": { "method": "npm", "packages": ["tsx"] }
          }
        },
        {
          "id": "ts-lsp",
          "name": "typescript-language-server",
          "description": "TypeScript LSP",
          "default": true,
          "platforms": {
            "linux":   { "method": "npm", "packages": ["typescript-language-server"], "check": "command -v typescript-language-server" },
            "windows": { "method": "npm", "packages": ["typescript-language-server"] }
          }
        },
        {
          "id": "eslint",
          "name": "eslint",
          "description": "JavaScript/TypeScript linter",
          "default": true,
          "platforms": {
            "linux":   { "method": "npm", "packages": ["eslint"], "check": "command -v eslint" },
            "windows": { "method": "npm", "packages": ["eslint"] }
          }
        },
        {
          "id": "prettier",
          "name": "prettier",
          "description": "Code formatter",
          "default": true,
          "platforms": {
            "linux":   { "method": "npm", "packages": ["prettier"], "check": "command -v prettier" },
            "windows": { "method": "npm", "packages": ["prettier"] }
          }
        }
      ]
    }
  ]
}