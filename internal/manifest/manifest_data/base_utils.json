              "method": "custom",
              "check": "command -v yq",
              "commands": [
                "set -e && ARCH=$(dpkg --print-architecture) && case \"$ARCH\" in amd64|arm64) ;; *) echo \"unsupported architecture: $ARCH\" >&2; exit 1 ;; esac && curl -fsSLo /usr/local/bin/yq \"https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${ARCH}\" && chmod +x /usr/local/bin/yq"
              ],
              "size_kb": 11000
            },
            "windows": {
