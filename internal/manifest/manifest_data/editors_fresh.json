{
  "id": "editors_fresh",
  "name": "Fresh IDE",
  "description": "Fresh — terminal-based IDE with LSP, plugins, vim mode, SSH remote editing",
  "subcategories": [
    {
      "id": "fresh_app",
      "name": "Editor",
      "packages": [
        {
          "id": "fresh",
          "name": "fresh",
          "description": "Terminal IDE",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v fresh",
              "commands": [
                "set -e && URL=$(curl -s https://api.github.com/repos/sinelaw/fresh/releases/latest | grep \"browser_download_url.*_$(dpkg --print-architecture)\\.deb\" | cut -d '\"' -f 4 | head -1) && [ -n \"$URL\" ] && curl -fsSLo /tmp/fresh-editor.deb \"$URL\" && apt-get install -y /tmp/fresh-editor.deb && rm -f /tmp/fresh-editor.deb"
              ],
              "size_kb": 35000
            },
            "windows": {
              "method": "winget",
              "id": "sinelaw.fresh-editor"
            }
          }
        }
      ]
    },
    {
      "id": "fresh_lsp_servers",
      "name": "LSP Servers (used by Fresh)",
      "packages": [
        {
          "id": "fresh-pylsp",
          "name": "python-lsp-server",
          "description": "Python LSP server",
          "default": true,
          "platforms": {
            "linux": {
              "method": "pipx",
              "packages": [
                "python-lsp-server[all]"
              ],
              "check": "command -v pylsp"
            },
            "windows": {
              "method": "pip",
              "packages": [
                "python-lsp-server[all]"
              ]
            }
          }
        },
        {
          "id": "fresh-rust-lsp",
          "name": "rust-analyzer (for Fresh)",
          "description": "Rust LSP (also used by other editors)",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v rust-analyzer || /usr/local/bin/rustup component list --installed 2>/dev/null | grep -q \"^rust-analyzer\"",
              "commands": [
                "set -e && /usr/local/bin/rustup component add rust-analyzer"
              ]
            }
          }
        },
        {
          "id": "fresh-go-lsp",
          "name": "gopls (for Fresh)",
          "description": "Go LSP",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v gopls",
              "commands": [
                "set -e && GOBIN=/usr/local/bin $(command -v go || echo /usr/local/go/bin/go) install golang.org/x/tools/gopls@latest"
              ]
            }
          }
        },
        {
          "id": "fresh-clangd",
          "name": "clangd (for Fresh)",
          "description": "C/C++ LSP",
          "default": false,
          "platforms": {
            "linux": {
              "method": "apt",
              "packages": [
                "clangd"
              ],
              "check": "command -v clangd"
            }
          }
        },
        {
          "id": "fresh-ts-lsp",
          "name": "typescript-language-server (for Fresh)",
          "description": "TypeScript/JavaScript LSP",
          "default": false,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "typescript-language-server",
                "typescript"
              ],
              "check": "command -v typescript-language-server"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "typescript-language-server",
                "typescript"
              ]
            }
          }
        },
        {
          "id": "fresh-vue-lsp",
          "name": "vue-language-server (for Fresh)",
          "description": "Vue LSP",
          "default": false,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "@vue/language-server"
              ],
              "check": "command -v vue-language-server"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "@vue/language-server"
              ]
            }
          }
        },
        {
          "id": "fresh-svelte-lsp",
          "name": "svelte-language-server",
          "description": "Svelte LSP",
          "default": false,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "svelte-language-server"
              ],
              "check": "command -v svelteserver"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "svelte-language-server"
              ]
            }
          }
        },
        {
          "id": "fresh-bash-lsp",
          "name": "bash-language-server (for Fresh)",
          "description": "Bash LSP",
          "default": false,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "bash-language-server"
              ],
              "check": "command -v bash-language-server"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "bash-language-server"
              ]
            }
          }
        },
        {
          "id": "fresh-yaml-lsp",
          "name": "yaml-language-server",
          "description": "YAML LSP",
          "default": false,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "yaml-language-server"
              ],
              "check": "command -v yaml-language-server"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "yaml-language-server"
              ]
            }
          }
        },
        {
          "id": "fresh-json-lsp",
          "name": "vscode-json-language-server",
          "description": "JSON LSP",
          "default": false,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "vscode-langservers-extracted"
              ],
              "check": "command -v vscode-json-language-server"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "vscode-langservers-extracted"
              ]
            }
          }
        },
        {
          "id": "fresh-dockerfile-lsp",
          "name": "dockerfile-language-server",
          "description": "Dockerfile LSP",
          "default": false,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "dockerfile-language-server-nodejs"
              ],
              "check": "command -v docker-langserver"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "dockerfile-language-server-nodejs"
              ]
            }
          }
        }
      ]
    }
  ]
}
