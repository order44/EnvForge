{
  "id": "containers",
  "name": "Containers & Virtualization",
  "description": "Docker, distrobox, podman and related tools",
  "subcategories": [
    {
      "id": "docker",
      "name": "Docker",
      "packages": [
        {
          "id": "docker",
          "name": "docker",
          "description": "Container runtime",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v docker",
              "commands": [
                "curl -fsSL https://get.docker.com | sh"
              ]
            },
            "windows": {
              "method": "winget",
              "id": "Docker.DockerDesktop"
            }
          }
        },
        {
          "id": "docker-compose",
          "name": "docker-compose",
          "description": "Multi-container orchestration",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "docker compose version >/dev/null 2>&1",
              "commands": [
                "set -e && if ! command -v docker >/dev/null 2>&1; then curl -fsSL https://get.docker.com | sh; fi && apt-get install -y docker-compose-plugin"
              ],
              "size_kb": 18000
            }
          }
        },
        {
          "id": "lazydocker",
          "name": "lazydocker",
          "description": "TUI for Docker management",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v lazydocker",
              "commands": [
                "set -e && curl -fsSL https://raw.githubusercontent.com/jesseduffield/lazydocker/master/scripts/install_update_linux.sh | bash && install -m 755 \"$HOME/.local/bin/lazydocker\" /usr/local/bin/lazydocker"
              ],
              "size_kb": 18000
            }
          }
        }
      ]
    },
    {
      "id": "distrobox",
      "name": "Distrobox",
      "packages": [
        {
          "id": "distrobox",
          "name": "distrobox",
          "description": "Run any Linux distro in a container",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v distrobox",
              "commands": [
                "curl -s https://raw.githubusercontent.com/89luca89/distrobox/main/install | sh -s -- --prefix /usr/local"
              ],
              "size_kb": 12000
            }
          }
        }
      ]
    },
    {
      "id": "podman",
      "name": "Podman",
      "packages": [
        {
          "id": "podman",
          "name": "podman",
          "description": "Daemonless container engine",
          "default": false,
          "platforms": {
            "linux": {
              "method": "apt",
              "packages": [
                "podman"
              ],
              "check": "command -v podman"
            }
          }
        }
      ]
    }
  ]
}
