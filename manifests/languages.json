              "packages": [
                "typescript"
              ],
              "check": "command -v tsc || npm list -g --depth=0 typescript >/dev/null 2>&1"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "typescript"
              ]
            }
          }
        },
        {
          "id": "tsx",
          "name": "tsx",
          "description": "Run TypeScript directly",
          "default": false,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "tsx"
              ],
              "check": "command -v tsx || npm list -g --depth=0 tsx >/dev/null 2>&1"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "tsx"
              ]
            }
          }
        },
        {
          "id": "ts-lsp",
          "name": "typescript-language-server",
          "description": "TypeScript LSP",
          "default": true,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "typescript-language-server"
              ],
              "check": "command -v typescript-language-server || npm list -g --depth=0 typescript-language-server >/dev/null 2>&1"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "typescript-language-server"
              ]
            }
          }
        },
        {
          "id": "eslint",
          "name": "eslint",
          "description": "JavaScript/TypeScript linter",
          "default": true,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "eslint"
              ],
              "check": "command -v eslint || npm list -g --depth=0 eslint >/dev/null 2>&1"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "eslint"
              ]
            }
          }
        },
        {
          "id": "prettier",
          "name": "prettier",
          "description": "Code formatter",
          "default": true,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "prettier"
              ],
              "check": "command -v prettier || npm list -g --depth=0 prettier >/dev/null 2>&1"
            },
            "windows": {
              "method": "npm",
              "packages": [
                "prettier"
              ]
            }
          }
        }
      ]
    }
  ]
}
