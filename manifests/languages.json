              "check": "command -v pnpm || npm list -g --depth=0 pnpm >/dev/null 2>&1"
            },
            "windows": {
              "method": "winget",
              "id": "pnpm.pnpm"
            }
          }
        },
        {
          "id": "typescript",
          "name": "typescript",
