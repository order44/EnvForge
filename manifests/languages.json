{
  "id": "languages",
  "name": "Programming Languages",
  "description": "Compilers, runtimes, LSPs, package managers",
  "subcategories": [
    {
      "id": "python",
      "name": "Python",
      "packages": [
        {
          "id": "python3",
          "name": "python3",
          "description": "Python 3 interpreter + pip + venv",
          "default": true,
          "platforms": {
            "linux": {
              "method": "apt",
              "packages": [
                "python3",
                "python3-pip",
                "python3-venv",
                "python3-dev"
              ],
              "check": "command -v python3 && command -v pip3"
            },
            "windows": {
              "method": "custom",
              "check": "where py >NUL 2>&1 || where python >NUL 2>&1",
              "commands": [
                "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ErrorActionPreference='Stop'; $url='https://www.python.org/ftp/python/3.12.10/python-3.12.10-amd64.exe'; $dst=Join-Path $env:TEMP 'python-3.12.10-amd64.exe'; Invoke-WebRequest -UseBasicParsing -Uri $url -OutFile $dst; Start-Process -FilePath $dst -ArgumentList '/quiet InstallAllUsers=1 PrependPath=1 Include_pip=1 Include_test=0' -Wait; Remove-Item $dst -Force\""
              ],
              "size_kb": 30000,
              "note": "Official Python installer from python.org with silent install, pip enabled, and PATH update."
            }
          }
        },
        {
          "id": "uv",
          "name": "uv",
          "description": "Fast Python package manager",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v uv",
              "commands": [
                "set -e && curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local INSTALLER_NO_MODIFY_PATH=1 sh"
              ],
              "size_kb": 18000
            },
            "windows": {
              "method": "winget",
              "id": "astral-sh.uv"
            }
          }
        },
        {
          "id": "pyenv",
          "name": "pyenv",
          "description": "Python version manager",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "REAL_HOME=$(getent passwd ${SUDO_USER:-$USER} | cut -d: -f6); test -d \"${PYENV_ROOT:-$REAL_HOME/.pyenv}\"",
              "commands": [
                "set -e && apt-get install -y make libssl-dev zlib1g-dev libbz2-dev libreadline-dev libsqlite3-dev llvm libncursesw5-dev xz-utils tk-dev libxml2-dev libxmlsec1-dev libffi-dev liblzma-dev && REAL_USER=${SUDO_USER:-$USER} && su -l \"$REAL_USER\" -c \"curl -fsSL https://pyenv.run | bash\""
              ]
            }
          }
        },
        {
          "id": "ruff",
          "name": "ruff",
          "description": "Python linter + formatter (Rust)",
          "default": true,
          "platforms": {
            "linux": {
              "method": "pip",
              "packages": [
                "ruff"
              ],
              "check": "command -v ruff"
            },
            "windows": {
              "method": "winget",
              "id": "astral-sh.ruff"
            }
          }
        },
        {
          "id": "mypy",
          "name": "mypy",
          "description": "Static type checker for Python",
          "default": false,
          "platforms": {
            "linux": {
              "method": "pip",
              "packages": [
                "mypy"
              ],
              "check": "command -v mypy"
            },
            "windows": {
              "method": "pip",
              "packages": [
                "mypy"
              ]
            }
          }
        },
        {
          "id": "black",
          "name": "black",
          "description": "Python code formatter",
          "default": false,
          "platforms": {
            "linux": {
              "method": "pip",
              "packages": [
                "black"
              ],
              "check": "command -v black"
            },
            "windows": {
              "method": "pip",
              "packages": [
                "black"
              ]
            }
          }
        },
        {
          "id": "poetry",
          "name": "poetry",
          "description": "Python dependency manager",
          "default": false,
          "platforms": {
            "linux": {
              "method": "pip",
              "packages": [
                "poetry"
              ],
              "check": "command -v poetry"
            },
            "windows": {
              "method": "pip",
              "packages": [
                "poetry"
              ]
            }
          }
        }
      ]
    },
    {
      "id": "golang",
      "name": "Go",
      "packages": [
        {
          "id": "go",
          "name": "go",
          "description": "Go compiler and tools",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v go || test -x /usr/local/go/bin/go",
              "commands": [
                "set -e && GO_ARCH=$(dpkg --print-architecture) && case \"$GO_ARCH\" in amd64|arm64) ;; *) echo \"unsupported architecture: $GO_ARCH\" >&2; exit 1 ;; esac && GO_VERSION=$(curl -fsSL https://go.dev/VERSION?m=text | head -n 1) && TMP=\"/tmp/${GO_VERSION}.linux-${GO_ARCH}.tar.gz\" && curl -fsSLo \"$TMP\" \"https://go.dev/dl/${GO_VERSION}.linux-${GO_ARCH}.tar.gz\" && rm -rf /usr/local/go && tar -C /usr/local -xzf \"$TMP\" && ln -sf /usr/local/go/bin/go /usr/local/bin/go && ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt && rm -f \"$TMP\""
              ],
              "size_kb": 150000
            },
            "windows": {
              "method": "winget",
              "id": "GoLang.Go"
            }
          }
        },
        {
          "id": "gopls",
          "name": "gopls",
          "description": "Go LSP server",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v gopls",
              "commands": [
                "set -e && GOBIN=/usr/local/bin $(command -v go || echo /usr/local/go/bin/go) install golang.org/x/tools/gopls@latest"
              ]
            }
          }
        },
        {
          "id": "golangci-lint",
          "name": "golangci-lint",
          "description": "Go linter aggregator",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v golangci-lint",
              "commands": [
                "set -e && GOBIN=/usr/local/bin $(command -v go || echo /usr/local/go/bin/go) install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest"
              ]
            }
          }
        },
        {
          "id": "delve",
          "name": "delve",
          "description": "Go debugger",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v dlv",
              "commands": [
                "set -e && GOBIN=/usr/local/bin $(command -v go || echo /usr/local/go/bin/go) install github.com/go-delve/delve/cmd/dlv@latest"
              ]
            }
          }
        },
        {
          "id": "air",
          "name": "air",
          "description": "Live reload for Go apps",
          "default": false,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v air",
              "commands": [
                "set -e && GOBIN=/usr/local/bin $(command -v go || echo /usr/local/go/bin/go) install github.com/air-verse/air@latest"
              ]
            }
          }
        }
      ]
    },
    {
      "id": "rust",
      "name": "Rust",
      "packages": [
        {
          "id": "rustup",
          "name": "rustup",
          "description": "Rust toolchain installer",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v rustup >/dev/null 2>&1 || { REAL_HOME=$(getent passwd ${SUDO_USER:-$USER} | cut -d: -f6); test -x \"$REAL_HOME/.cargo/bin/rustup\"; }",
              "commands": [
                "set -e && REAL_USER=${SUDO_USER:-$USER} && su -l \"$REAL_USER\" -c \"curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --profile minimal\" && REAL_HOME=$(getent passwd \"$REAL_USER\" | cut -d: -f6) && install -m 755 \"$REAL_HOME/.cargo/bin/rustup\" /usr/local/bin/rustup && install -m 755 \"$REAL_HOME/.cargo/bin/cargo\" /usr/local/bin/cargo && install -m 755 \"$REAL_HOME/.cargo/bin/rustc\" /usr/local/bin/rustc"
              ],
              "size_kb": 120000
            },
            "windows": {
              "method": "winget",
              "id": "Rustlang.Rustup"
            }
          }
        },
        {
          "id": "rust-analyzer",
          "name": "rust-analyzer",
          "description": "Rust LSP server",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v rust-analyzer || /usr/local/bin/rustup component list --installed 2>/dev/null | grep -q \"^rust-analyzer\"",
              "commands": [
                "set -e && /usr/local/bin/rustup component add rust-analyzer"
              ]
            }
          }
        },
        {
          "id": "clippy",
          "name": "clippy",
          "description": "Rust linter",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v cargo-clippy >/dev/null 2>&1 || /usr/local/bin/rustup component list --installed 2>/dev/null | grep -q \"^clippy\"",
              "commands": [
                "set -e && /usr/local/bin/rustup component add clippy"
              ]
            }
          }
        },
        {
          "id": "rustfmt",
          "name": "rustfmt",
          "description": "Rust code formatter",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v rustfmt >/dev/null 2>&1 || /usr/local/bin/rustup component list --installed 2>/dev/null | grep -q \"^rustfmt\"",
              "commands": [
                "set -e && /usr/local/bin/rustup component add rustfmt"
              ]
            }
          }
        }
      ]
    },
    {
      "id": "js_ts",
      "name": "JavaScript / TypeScript",
      "packages": [
        {
          "id": "nodejs",
          "name": "nodejs-lts",
          "description": "Node.js LTS + npm",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v node && command -v npm",
              "commands": [
                "set -e && apt-get install -y ca-certificates curl gnupg && mkdir -p /etc/apt/keyrings && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && NODE_MAJOR=22 && echo \"deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main\" > /etc/apt/sources.list.d/nodesource.list && apt-get update && apt-get install -y nodejs"
              ],
              "size_kb": 120000
            },
            "windows": {
              "method": "winget",
              "id": "OpenJS.NodeJS.LTS"
            }
          }
        },
        {
          "id": "pnpm",
          "name": "pnpm",
          "description": "Fast npm alternative",
          "default": false,
          "platforms": {
            "linux": {
              "method": "npm",
              "packages": [
                "pnpm"
