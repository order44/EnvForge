        { "id": "ext-yaml", "name": "YAML", "description": "YAML language support", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "redhat.vscode-yaml" }, "windows": { "method": "vscode_ext", "id": "redhat.vscode-yaml" } } },
        { "id": "ext-markdown", "name": "Markdown All in One", "description": "Markdown editing tools", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "yzhang.markdown-all-in-one" }, "windows": { "method": "vscode_ext", "id": "yzhang.markdown-all-in-one" } } },
        { "id": "ext-editorconfig", "name": "EditorConfig", "description": "EditorConfig support", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "EditorConfig.EditorConfig" }, "windows": { "method": "vscode_ext", "id": "EditorConfig.EditorConfig" } } },
        { "id": "ext-path-intellisense", "name": "Path Intellisense", "description": "File path autocomplete", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "christian-kohler.path-intellisense" }, "windows": { "method": "vscode_ext", "id": "christian-kohler.path-intellisense" } } },
        { "id": "ext-remote-wsl", "name": "Remote - WSL", "description": "WSL development support", "default": false,
          "platforms": { "windows": { "method": "vscode_ext", "id": "ms-vscode-remote.remote-wsl" } } },
        { "id": "ext-spell", "name": "Code Spell Checker", "description": "Spelling checker for code", "default": false,
          "platforms": { "linux": { "method": "vscode_ext", "id": "streetsidesoftware.code-spell-checker" }, "windows": { "method": "vscode_ext", "id": "streetsidesoftware.code-spell-checker" } } },
        { "id": "ext-thunder", "name": "Thunder Client", "description": "REST API testing client", "default": false,
          "platforms": { "linux": { "method": "vscode_ext", "id": "rangav.vscode-thunder-client" }, "windows": { "method": "vscode_ext", "id": "rangav.vscode-thunder-client" } } }
      ]
    },
    {
      "id": "vscode_themes",
      "name": "Themes & Icons",
      "packages": [
        { "id": "ext-catppuccin", "name": "Catppuccin", "description": "Pastel color theme", "default": true,
