        { "id": "ext-errorlens", "name": "Error Lens", "description": "Inline error highlighting", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "usernamehw.errorlens" }, "windows": { "method": "vscode_ext", "id": "usernamehw.errorlens" } } },
        { "id": "ext-todotree", "name": "Todo Tree", "description": "TODO/FIXME tree view", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "Gruntfuggly.todo-tree" }, "windows": { "method": "vscode_ext", "id": "Gruntfuggly.todo-tree" } } },
        { "id": "ext-prettier", "name": "Prettier", "description": "Code formatter", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "esbenp.prettier-vscode" }, "windows": { "method": "vscode_ext", "id": "esbenp.prettier-vscode" } } },
        { "id": "ext-eslint", "name": "ESLint", "description": "JS/TS linter integration", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "dbaeumer.vscode-eslint" }, "windows": { "method": "vscode_ext", "id": "dbaeumer.vscode-eslint" } } },
