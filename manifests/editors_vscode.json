{
  "id": "editors_vscode",
  "name": "VS Code",
  "description": "Visual Studio Code editor, extensions, themes",
  "subcategories": [
    {
      "id": "vscode_app",
      "name": "Editor",
      "packages": [
        {
          "id": "vscode",
          "name": "vscode",
          "description": "Visual Studio Code editor",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v code",
              "commands": [
                "set -e && rm -f /usr/share/keyrings/ms.gpg && curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --yes --dearmor -o /usr/share/keyrings/ms.gpg && echo 'deb [arch=amd64 signed-by=/usr/share/keyrings/ms.gpg] https://packages.microsoft.com/repos/code stable main' > /etc/apt/sources.list.d/vscode.list && apt-get update && apt-get install -y code"
              ]
            },
            "windows": { "method": "winget", "id": "Microsoft.VisualStudioCode" }
          }
        }
      ]
    },
    {
      "id": "vscode_lang",
      "name": "Language Extensions",
      "packages": [
        { "id": "ext-cpp", "name": "C/C++", "description": "C/C++ IntelliSense and debugging", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "ms-vscode.cpptools-extension-pack" }, "windows": { "method": "vscode_ext", "id": "ms-vscode.cpptools-extension-pack" } } },
        { "id": "ext-python", "name": "Python", "description": "Python language support", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "ms-python.python" }, "windows": { "method": "vscode_ext", "id": "ms-python.python" } } },
        { "id": "ext-pylance", "name": "Pylance", "description": "Fast Python language server", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "ms-python.vscode-pylance" }, "windows": { "method": "vscode_ext", "id": "ms-python.vscode-pylance" } } },
        { "id": "ext-go", "name": "Go", "description": "Go language support", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "golang.go" }, "windows": { "method": "vscode_ext", "id": "golang.go" } } },
        { "id": "ext-rust", "name": "rust-analyzer", "description": "Rust language support", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "rust-lang.rust-analyzer" }, "windows": { "method": "vscode_ext", "id": "rust-lang.rust-analyzer" } } },
        { "id": "ext-csharp", "name": "C# Dev Kit", "description": "C# language support", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "ms-dotnettools.csdevkit" }, "windows": { "method": "vscode_ext", "id": "ms-dotnettools.csdevkit" } } },
        { "id": "ext-java", "name": "Java Extension Pack", "description": "Java development tools", "default": false,
          "platforms": { "linux": { "method": "vscode_ext", "id": "vscjava.vscode-java-pack" }, "windows": { "method": "vscode_ext", "id": "vscjava.vscode-java-pack" } } },
        { "id": "ext-vue", "name": "Vue - Official", "description": "Vue.js language support", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "Vue.volar" }, "windows": { "method": "vscode_ext", "id": "Vue.volar" } } },
        { "id": "ext-svelte", "name": "Svelte", "description": "Svelte language support", "default": false,
          "platforms": { "linux": { "method": "vscode_ext", "id": "svelte.svelte-vscode" }, "windows": { "method": "vscode_ext", "id": "svelte.svelte-vscode" } } },
        { "id": "ext-pwsh", "name": "PowerShell", "description": "PowerShell language support", "default": false,
          "platforms": { "linux": { "method": "vscode_ext", "id": "ms-vscode.powershell" }, "windows": { "method": "vscode_ext", "id": "ms-vscode.powershell" } } },
        { "id": "ext-bash", "name": "Bash IDE", "description": "Bash language support", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "mads-hartmann.bash-ide-vscode" }, "windows": { "method": "vscode_ext", "id": "mads-hartmann.bash-ide-vscode" } } },
        { "id": "ext-shellcheck", "name": "ShellCheck", "description": "Shell script linting", "default": true,
          "platforms": { "linux": { "method": "vscode_ext", "id": "timonwong.shellcheck" }, "windows": { "method": "vscode_ext", "id": "timonwong.shellcheck" } } }
      ]
    },
    {
