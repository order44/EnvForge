{
  "id": "editors_vscode",
  "name": "VS Code",
  "description": "Visual Studio Code editor, extensions, themes",
  "subcategories": [
    {
      "id": "vscode_app",
      "name": "Editor",
      "packages": [
        {
          "id": "vscode",
          "name": "vscode",
          "description": "Visual Studio Code editor",
          "default": true,
          "platforms": {
            "linux": {
              "method": "custom",
              "check": "command -v code",
              "commands": [
                "set -e && apt-get install -y wget gpg && wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft.gpg && cat > /etc/apt/sources.list.d/vscode.sources <<'EOF'\nTypes: deb\nURIs: https://packages.microsoft.com/repos/code\nSuites: stable\nComponents: main\nArchitectures: amd64 arm64 armhf\nSigned-By: /usr/share/keyrings/microsoft.gpg\nEOF\napt-get update && apt-get install -y code"
              ],
              "size_kb": 250000
            },
            "windows": {
              "method": "winget",
              "id": "Microsoft.VisualStudioCode"
            }
          }
        }
      ]
    },
